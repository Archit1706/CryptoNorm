# cryptonorm configuration — public feeds only, no secrets required.
# Copy to `.env` and adjust. All values shown are the defaults.

# --- general ---
CN_LOG_LEVEL=INFO
CN_LOG_JSON=true                       # false => human-readable console logs

# --- market data ---
# Canonical symbols (BASE-QUOTE). Adapters map these to each venue's raw symbol.
CN_SYMBOLS=BTC-USD,ETH-USD
# Which exchanges to ingest.
CN_EXCHANGES=coinbase,binance,kraken

# --- reliability ---
CN_STALENESS_SECONDS=10                 # flag a feed STALE if silent this long
CN_RECONNECT_BASE_SECONDS=0.5           # backoff base
CN_RECONNECT_MAX_SECONDS=30             # backoff ceiling

# --- exchange endpoints (public, no auth) ---
# binance.com is geoblocked (HTTP 451) in many regions; binance.us has USD pairs.
CN_COINBASE_WS_URL=wss://advanced-trade-ws.coinbase.com
CN_BINANCE_WS_URL=wss://stream.binance.us:9443/ws
CN_BINANCE_REST_URL=https://api.binance.us/api/v3
CN_KRAKEN_WS_URL=wss://ws.kraken.com/v2
CN_KRAKEN_BOOK_DEPTH=10

# --- kafka / redis (phase 2+) ---
# Host dev connects to Kafka's host-facing listener (compose maps 29092).
# Inside compose, services override this to kafka:9092.
CN_KAFKA_BOOTSTRAP=localhost:29092
# Redis on host port 6380 (compose maps 6380->6379) to avoid clashing with a
# local Redis already on 6379. Inside compose, services use redis://redis:6379/0.
CN_REDIS_URL=redis://localhost:6380/0
CN_CONSUMER_GROUP=cn-risk
# Topic names (versioned suffix lets the schema evolve without clobbering).
CN_TOPIC_BOOK=md.book.v1
CN_TOPIC_TRADE=md.trade.v1
CN_TOPIC_FILL=paper.fills.v1
# Top-N book levels cached to Redis for the dashboard.
CN_BOOK_TOP_N=10

# --- paper-fill simulator + risk (phase 4) ---
CN_SIM_INTERVAL_SECONDS=1.5             # mean seconds between simulated fills
CN_SIM_MAX_QTY=0.05                     # max fill size (base units)
CN_SIM_FEE_RATE=0.001                   # 10 bps taker fee
CN_RISK_INTERVAL_SECONDS=1.0            # P&L/risk recompute cadence
CN_RECON_INTERVAL_SECONDS=5.0           # position reconciliation cadence
CN_VAR_WINDOW=120                       # rolling samples for historical VaR
# Max Kafka message size (full L2 book snapshots are ~1.6 MB, over the 1 MB
# default). Must stay <= the broker's KAFKA_MESSAGE_MAX_BYTES in compose.
CN_MAX_MESSAGE_BYTES=10485760

# --- alert thresholds (phase 5) ---
CN_ALERT_MAX_DRAWDOWN_USD=5000
CN_ALERT_MAX_EXPOSURE_USD=50000
CN_ALERT_SPREAD_BPS=50                  # cross-exchange spread alert (basis points)

# --- dashboard / api (phase 5) ---
CN_API_HOST=0.0.0.0
CN_API_PORT=8000
CN_DASHBOARD_INTERVAL_SECONDS=1.0       # how often the dashboard WS pushes state
